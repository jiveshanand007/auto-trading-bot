# Copy to .env and fill in. Never commit .env.
BOT_DATABASE_URL=postgresql+psycopg2://bot:bot@localhost:5432/trading_bot
BOT_DATA_DIR=./data

# Binance — leave blank for now; klines downloading needs no auth.
# Use a TRADE-only key (no withdraw) when you reach Week 5.
BOT_BINANCE_API_KEY=
BOT_BINANCE_API_SECRET=
BOT_BINANCE_TESTNET=true

BOT_LOG_LEVEL=INFO
BOT_LOG_JSON=false
