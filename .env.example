# Copy to .env and fill in. Never commit .env.
BOT_DATABASE_URL=postgresql+psycopg2://bot:bot@localhost:5432/trading_bot
BOT_DATA_DIR=./data

# Binance Testnet credentials (get free keys at testnet.binance.vision — log in with GitHub)
# Testnet gives you 1 BTC + 10,000 USDT to play with. Set testnet=true (default).
BOT_BINANCE_API_KEY=your-testnet-api-key-here
BOT_BINANCE_API_SECRET=your-testnet-api-secret-here
BOT_BINANCE_TESTNET=true
# URL overrides — pick one depending on where your keys came from:
#   demo.binance.com paper trading → use demo-api.binance.com
#   testnet.binance.vision         → use testnet.binance.vision (default)
# BOT_BINANCE_TESTNET_URL=https://demo-api.binance.com/api
# BOT_BINANCE_TESTNET_URL=https://testnet.binance.vision/api
# BOT_BINANCE_LIVE_URL=https://api.binance.com/api

# Binance Futures Testnet credentials (SEPARATE from spot — get at testnet.binancefuture.com)
# BOT_BINANCE_FUTURES_API_KEY=your-futures-testnet-key-here
# BOT_BINANCE_FUTURES_API_SECRET=your-futures-testnet-secret-here
BOT_BINANCE_FUTURES_TESTNET=true
# BOT_FUTURES_LEVERAGE=5
# BOT_FUTURES_MARGIN_TYPE=ISOLATED

BOT_LOG_LEVEL=INFO
BOT_LOG_JSON=false
